# Discord Bot Token (Get this from the Discord Developer Portal)
TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# MongoDB SRV Connection String (Get this from MongoDB Atlas -> Connect -> Drivers)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=YourApp

# Bot Owner ID (your Discord user ID — used for owner-only commands)
OWNER_ID=YOUR_DISCORD_USER_ID

# Guild ID (your server ID — used for slash command syncing)
GUILD_ID=YOUR_GUILD_ID
